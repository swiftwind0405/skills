{
  "monorepo_name": "web-suite",
  "monorepo_root": "~/Workspace/projects/web-suite",
  "defaults": {
    "ats": "~/Workspace/projects/backend/ats"
  },
  "entries": [
    {
      "aliases": ["admin", "pc", "后台管理"],
      "path": "~/Workspace/projects/web-suite/apps/admin",
      "stack": "React 前端"
    },
    {
      "aliases": ["h5", "前端h5"],
      "path": "~/Workspace/projects/web-suite/apps/h5",
      "stack": "React H5"
    },
    {
      "aliases": ["onboarding-h5", "onboarding"],
      "path": "~/Workspace/projects/web-suite/apps/onboarding-h5",
      "stack": "React H5"
    },
    {
      "aliases": ["ats", "后端ats", "backend"],
      "path": "~/Workspace/projects/backend/ats",
      "stack": "后端服务"
    }
  ]
}
