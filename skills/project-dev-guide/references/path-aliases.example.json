{
  "backend_root": "/absolute/path/to/backend",
  "frontend_monorepo_name": "web-monorepo",
  "frontend_monorepo_root": "/absolute/path/to/frontend",
  "ai_root": "/absolute/path/to/ai",
  "defaults": {
    "backend": "/absolute/path/to/backend",
    "frontend": "/absolute/path/to/frontend",
    "ai": "/absolute/path/to/ai",
    "ats": "/absolute/path/to/backend/ats"
  },
  "entries": [
    {
      "aliases": ["admin", "pc", "后台管理"],
      "path": "/absolute/path/to/frontend/apps/admin",
      "stack": "React 前端"
    },
    {
      "aliases": ["h5", "前端h5"],
      "path": "/absolute/path/to/frontend/apps/h5",
      "stack": "React H5"
    },
    {
      "aliases": ["ats-web", "前端ats"],
      "path": "/absolute/path/to/frontend/apps/ats",
      "stack": "React 前端"
    },
    {
      "aliases": ["packages", "shared-packages", "前端共享包"],
      "path": "/absolute/path/to/frontend/packages",
      "stack": "前端共享包"
    },
    {
      "aliases": ["ats", "后端ats"],
      "path": "/absolute/path/to/backend/ats",
      "stack": "Java 后端"
    },
    {
      "aliases": ["aida"],
      "path": "/absolute/path/to/ai/aida",
      "stack": "AI monorepo"
    }
  ]
}
